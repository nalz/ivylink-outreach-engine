# ============================================================
# IvyLink Outreach Engine — Environment Variables
# ============================================================
# Copy this to .env.local for local dev.
# Set all variables in Railway for production.
# ============================================================

# ── Auth ─────────────────────────────────────────────────────
# The single admin password for the dashboard
UI_ADMIN_KEY=your-secret-key-here

# Separate secret for JWT signing (optional, falls back to UI_ADMIN_KEY)
JWT_SECRET=your-jwt-secret-32-chars-minimum

# ── Database ──────────────────────────────────────────────────
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── AI ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Apify ─────────────────────────────────────────────────────
APIFY_TOKEN=apify_api_xxx

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.railway.app
DASHBOARD_URL=https://your-app.railway.app/outreach
NODE_ENV=production
