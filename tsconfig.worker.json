{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist/workers",
    "rootDir": "./",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["workers/**/*.ts", "src/types/**/*.ts"],
  "exclude": ["node_modules", "src/app", ".next"]
}
